{"id":1,"name":"Prelude1","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":241,"indent":0,"parameters":[{"name":"Official_Loop (Get_RPM2000)","volume":60,"pitch":100,"pan":0}]},{"code":230,"indent":0,"parameters":[60]},{"code":222,"indent":0,"parameters":[]},{"code":205,"indent":0,"parameters":[4,{"list":[{"code":4,"indent":null},{"code":4,"indent":null},{"code":4,"indent":null},{"code":4,"indent":null},{"code":4,"indent":null},{"code":4,"indent":null},{"code":4,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":false}]},{"code":505,"indent":0,"parameters":[{"code":4,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":4,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":4,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":4,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":4,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":4,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":4,"indent":null}]},{"code":205,"indent":0,"parameters":[3,{"list":[{"code":16,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":false}]},{"code":505,"indent":0,"parameters":[{"code":16,"indent":null}]},{"code":230,"indent":0,"parameters":[60]},{"code":101,"indent":0,"parameters":["",0,0,2,"Aide"]},{"code":401,"indent":0,"parameters":["\"We've had some complaints,\\. Mr. Steel.\\. The special "]},{"code":401,"indent":0,"parameters":["toilets built on the beach are overflowing with waste...\\.\\. "]},{"code":401,"indent":0,"parameters":["There was a horrible smell,\\. and maggots are swarming...\\.\\.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Aide"]},{"code":401,"indent":0,"parameters":["\"A young child even fell into the waste.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"\\..\\..\\..\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Aide"]},{"code":401,"indent":0,"parameters":["\"A fire started at the tents,\\. so we have even less "]},{"code":401,"indent":0,"parameters":["than we already had.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Aide"]},{"code":401,"indent":0,"parameters":["\"A lion and komodo dragon have escaped the cages.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Aide"]},{"code":401,"indent":0,"parameters":["\"We don't have enough drinking water.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Aide"]},{"code":401,"indent":0,"parameters":["\"The orientals are killing, cooking, and eating the dogs.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Aide"]},{"code":401,"indent":0,"parameters":["\"The French are laying on the beach with their genitals and"]},{"code":401,"indent":0,"parameters":["breasts hanging out...\\. I'm worried a fight might break out "]},{"code":401,"indent":0,"parameters":["over it...\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Aide"]},{"code":401,"indent":0,"parameters":["\"And not to mention the-\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"WHAT'S A KOMODO DRAGON DOING ON THE BEACH ANYWAY???\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"Understand this...\\. You take care of the trouble...\\. That's"]},{"code":401,"indent":0,"parameters":["your job! That's what I'm paying you for, isn't it?\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"You're supposed to take care of this!\\. Don't bother me "]},{"code":401,"indent":0,"parameters":["with it again!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Aide"]},{"code":401,"indent":0,"parameters":["\"...B-But Mr. Steel, there are too many unpredictable events "]},{"code":401,"indent":0,"parameters":["occurring right now.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Aide"]},{"code":401,"indent":0,"parameters":["\"We predicted there would be 500 participants in this "]},{"code":401,"indent":0,"parameters":["contest, but 2000 people from across America are gathering "]},{"code":401,"indent":0,"parameters":["on this beach! And that's just America, there are over a "]},{"code":401,"indent":0,"parameters":["1000 from other countries as well.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Aide"]},{"code":401,"indent":0,"parameters":["\"This enthusiasm is cause for celebration, but with all of "]},{"code":401,"indent":0,"parameters":["these problems, there's a chance the race might be over "]},{"code":401,"indent":0,"parameters":["before it even begins. We only have two days to get things "]},{"code":401,"indent":0,"parameters":["sorted, sir.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"...Damn.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"All right! You can add another million! Go over the budget "]},{"code":401,"indent":0,"parameters":["and raise our capacity four-fold!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"And tell those foreigners to quit eating dogs and showing "]},{"code":401,"indent":0,"parameters":["off their dicks! If they don't quit it then just kick them "]},{"code":401,"indent":0,"parameters":["out! I don't care about their culture or religion or "]},{"code":401,"indent":0,"parameters":["ideology or whatever!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"While they're on this beach, they're under my 'rule'!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Aide"]},{"code":401,"indent":0,"parameters":["\"...Yes, sir.\""]},{"code":221,"indent":0,"parameters":[]},{"code":242,"indent":0,"parameters":[3]},{"code":230,"indent":0,"parameters":[30]},{"code":205,"indent":0,"parameters":[4,{"list":[{"code":39,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":39,"indent":null}]},{"code":222,"indent":0,"parameters":[]},{"code":205,"indent":0,"parameters":[3,{"list":[{"code":18,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":18,"indent":null}]},{"code":205,"indent":0,"parameters":[2,{"list":[{"code":19,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":19,"indent":null}]},{"code":205,"indent":0,"parameters":[2,{"list":[{"code":17,"indent":null},{"code":15,"parameters":[60],"indent":null},{"code":16,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":17,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":15,"parameters":[60],"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":16,"indent":null}]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"...\""]},{"code":205,"indent":0,"parameters":[2,{"list":[{"code":17,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":17,"indent":null}]},{"code":101,"indent":0,"parameters":["",0,0,2,"Lucy"]},{"code":401,"indent":0,"parameters":["\"...?\""]},{"code":225,"indent":0,"parameters":[7,5,60,false]},{"code":241,"indent":0,"parameters":[{"name":"Goofy (Thief_RPM2003)","volume":75,"pitch":100,"pan":0}]},{"code":205,"indent":0,"parameters":[2,{"list":[{"code":29,"parameters":[6],"indent":null},{"code":2,"indent":null},{"code":2,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":false}]},{"code":505,"indent":0,"parameters":[{"code