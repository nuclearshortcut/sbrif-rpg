{"id":1,"name":"MAIN_RaceExplain","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":92,"switch1Valid":false,"switch2Id":61,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":222,"indent":0,"parameters":[]},{"code":205,"indent":0,"parameters":[2,{"list":[{"code":18,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":18,"indent":null}]},{"code":205,"indent":0,"parameters":[3,{"list":[{"code":19,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":false}]},{"code":505,"indent":0,"parameters":[{"code":19,"indent":null}]},{"code":205,"indent":0,"parameters":[4,{"list":[{"code":16,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":16,"indent":null}]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"Journalists! I will now describe the development of the "]},{"code":401,"indent":0,"parameters":["race and the routes.\""]},{"code":108,"indent":0,"parameters":["Bring up map img"]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"Between the 3.7 thousand miles from San Diego to New York"]},{"code":401,"indent":0,"parameters":["and the Atlantic Ocean, there are checkpoints set in nine"]},{"code":401,"indent":0,"parameters":["places, including New York, as shown on this map.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"These checkpoints are to identify 'Race Ranking', "]},{"code":401,"indent":0,"parameters":["'Running Time', and to check for any illegal activity, such"]},{"code":401,"indent":0,"parameters":["as swapping horses.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"Each race up to their respective checkpoints will be "]},{"code":401,"indent":0,"parameters":["referred to as a 'Stage'.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"Nine Stages in total! The first stage that has just started"]},{"code":401,"indent":0,"parameters":["is a sprint race that will end at the Catholic Church "]},{"code":401,"indent":0,"parameters":["nine miles ahead.\""]},{"code":205,"indent":0,"parameters":[2,{"list":[{"code":17,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":17,"indent":null}]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\"We will decide and present a prize money bonus to the "]},{"code":401,"indent":0,"parameters":["champion of each Stage!\""]},{"code":221,"indent":0,"parameters":[]},{"code":201,"indent":0,"parameters":[0,95,23,11,0,0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":92,"switch1Valid":false,"switch2Id":62,"switch2Valid":false,"variableId":7,"variableValid":true,"variableValue":2},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"Gyro Zeppeli? Who is he?\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Aide"]},{"code":401,"indent":0,"parameters":["\"I don't know. He's not one of the predicted champion"]},{"code":401,"indent":0,"parameters":["candidates. He may just be an overeager cowboy. Or miner.\""]},{"code":221,"indent":0,"parameters":[]},{"code":122,"indent":0,"parameters":[7,7,0,0,2]},{"code":201,"indent":0,"parameters":[0,95,23,11,0,0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"B","selfSwitchValid":false,"switch1Id":95,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":7,"variableValid":true,"variableValue":20},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2,"Lucy"]},{"code":401,"indent":0,"parameters":["\"What's going on. They've run so far... but that man is "]},{"code":401,"indent":0,"parameters":["keeping up with them...\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Commentator"]},{"code":401,"indent":0,"parameters":["\"He's running even faster than the horses?! That's "]},{"code":401,"indent":0,"parameters":["impossible?!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Commentator"]},{"code":401,"indent":0,"parameters":["\"This 'Sandman' is fast! Look at him go!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Journalist"]},{"code":401,"indent":0,"parameters":["\"Impossible... a mere man outrunning a horse?!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"The secret is his running style! I will explain.\""]},{"code":205,"indent":0,"parameters":[4,{"list":[{"code":16,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":16,"indent":null}]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"When humans run, there's an impact when the foot hits the"]},{"code":401,"indent":0,"parameters":["ground, and the force of the blow knocks fatigue into"]},{"code":401,"indent":0,"parameters":["the joints and muscles.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"But in Sandmans case... When he runs, his heel touches the"]},{"code":401,"indent":0,"parameters":["ground for the briefest of moments! With that style of "]},{"code":401,"indent":0,"parameters":["running, the impact moves to the tip of his feet, and then"]},{"code":401,"indent":0,"parameters":["he kicks the ground at the perfect interval!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"Understand? The flow of his impact is going behind him"]},{"code":401,"indent":0,"parameters":["now! Not in front! As such, the fatigue felt by his feet "]},{"code":401,"indent":0,"parameters":["is reduced, and he is able to recycle the forces absorbed"]},{"code":401,"indent":0,"parameters":["to accelerate even further!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"This way his speed increases every time he kicks off a "]},{"code":401,"indent":0,"parameters":["rock or a cliff! And the longer he's in the air, the more "]},{"code":401,"indent":0,"parameters":["time his muscles have to relax. His heels are probably as "]},{"code":401,"indent":0,"parameters":["soft as a child's.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Lucy"]},{"code":401,"indent":0,"parameters":["\"Where did he learn that kind of running?\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"Who knows... Perhaps from his surroundings.\""]},{"code":221,"indent":0,"parameters":[]},{"code":201,"indent":0,"parameters":[0,101,10,7,0,0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":7,"variableValid":true,"variableValue":21},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2,"Steel"]},{"code":401,"indent":0,"parameters":["\"Huh... I had no idea there were so many people!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Lucy"]},{"code":401,"indent":0,"parameters":["\"Whoever does win this race... They'll be a hero to the "]},{"code":401,"indent":0,"parameters":["entire world.\""]},{"code":122,"indent":0,"parameters":[7,7,0,0,22]},{"code":221,"indent":0,"parameters":[]},{"code":201,"indent":0,"parameters":[0,95,23,11,0,0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true}],"x":0,"y":0},
