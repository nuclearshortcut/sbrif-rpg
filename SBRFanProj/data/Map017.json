{"id":1,"name":"Origin","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":211,"indent":0,"parameters":[0]},{"code":241,"indent":0,"parameters":[{"name":"HolyPast (TimeCave_RPGMusicPack_DavidVitas)","volume":70,"pitch":100,"pan":0}]},{"code":230,"indent":0,"parameters":[120]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2,"???"]},{"code":401,"indent":0,"parameters":["\"You there!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"???"]},{"code":401,"indent":0,"parameters":["\"Yes, yes, you!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"???"]},{"code":401,"indent":0,"parameters":["\"Come. Won't you lend this old woman a bit of your time?\""]},{"code":108,"indent":0,"parameters":["pic appears"]},{"code":101,"indent":0,"parameters":["",0,0,2,"???"]},{"code":401,"indent":0,"parameters":["\"I am a humble fortune teller.\\.\\. I have called you here, as"]},{"code":401,"indent":0,"parameters":["I sense great potential emanating from your spirit.\\....yes, "]},{"code":401,"indent":0,"parameters":["the power to wield a Stand!\\. The power to face the trials "]},{"code":401,"indent":0,"parameters":["that await you in the future.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":0,"parameters":["\"What is a Stand?\\.\\. What trials?\\.\\. All will be explained "]},{"code":401,"indent":0,"parameters":["in good time.\\. Before I explain, please answer a few "]},{"code":401,"indent":0,"parameters":["questions of my own... And pay the fee, of course, "]},{"code":401,"indent":0,"parameters":["heh-heh...\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":0,"parameters":["\"Now tell me,\\. who are you?\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":0,"parameters":["\"...\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":0,"parameters":["\"No,\\. not your name.\\.\\. That is irrelevant!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":0,"parameters":["\"Who ARE you?\\. What is your past?\\. What do you do?\\. Where "]},{"code":401,"indent":0,"parameters":["do you come from?\\. What defines you?\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":0,"parameters":["\"Who are you?\""]},{"code":112,"indent":0,"parameters":[]},{"code":118,"indent":1,"parameters":["Back"]},{"code":102,"indent":1,"parameters":[["An accomplished jockey","A foreign sailor from merchant family","A veteran of the war","A free-spirited cowboy","You don't need to know"],1,0,2,0]},{"code":402,"indent":1,"parameters":[0,"An accomplished jockey"]},{"code":101,"indent":2,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":2,"parameters":["\"You've been in horse races since you were a child.\\. The "]},{"code":401,"indent":2,"parameters":["sport is nothing new to you.\""]},{"code":101,"indent":2,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":2,"parameters":["\"You've procured a solid reputation and have a "]},{"code":401,"indent":2,"parameters":["decently-sized audience of fans.\\. That said, you're far "]},{"code":401,"indent":2,"parameters":["from the cream of the crop.\""]},{"code":101,"indent":2,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":2,"parameters":["\"As much as you want to move up in the racing world,\\. "]},{"code":401,"indent":2,"parameters":["you've begun to worry your skills may have reached their "]},{"code":401,"indent":2,"parameters":["ceiling.\""]},{"code":101,"indent":2,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":2,"parameters":["\"One day,\\. you hear about the Steel Ball Run race.\\. The "]},{"code":401,"indent":2,"parameters":["competition grabs your attention - this could be the "]},{"code":401,"indent":2,"parameters":["opportunity of a lifetime!\\. Winning wouldn't just boost "]},{"code":401,"indent":2,"parameters":["your reputation.\\. It'd make you a folk hero!\""]},{"code":101,"indent":2,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":2,"parameters":["\"With that in mind,\\. you make the decision to enter in "]},{"code":401,"indent":2,"parameters":["spite of the elevated dangers you're bound to encounter "]},{"code":401,"indent":2,"parameters":["while traveling across the country.\""]},{"code":101,"indent":2,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":2,"parameters":["\"Is this description correct?\""]},{"code":102,"indent":2,"parameters":[["Yes","No"],1,0,2,0]},{"code":402,"indent":2,"parameters":[0,"Yes"]},{"code":121,"indent":3,"parameters":[6,6,0]},{"code":113,"indent":3,"parameters":[]},{"code":0,"indent":3,"parameters":[]},{"code":402,"indent":2,"parameters":[1,"No"]},{"code":119,"indent":3,"parameters":["Back"]},{"code":0,"indent":3,"parameters":[]},{"code":404,"indent":2,"parameters":[]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[1,"A foreign sailor from merchant family"]},{"code":101,"indent":2,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":2,"parameters":["\"You come from an eastern country that's spent the last few "]},{"code":401,"indent":2,"parameters":["decades trying to acquire power on the world stage.\""]},{"code":101,"indent":2,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":2,"parameters":["\"In that country,\\. there are many merchant families "]},{"code":401,"indent":2,"parameters":["trying to capitalize off of the recent economic growth.\\. "]},{"code":401,"indent":2,"parameters":["Your own family is one of them, hoping to recover from a "]},{"code":401,"indent":2,"parameters":["period of decadence.\""]},{"code":101,"indent":2,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":2,"parameters":["\"You're one of the patriarch's younger children,\\. so you "]},{"code":401,"indent":2,"parameters":["don't have much sway. Hoping to make a name for yourself,\\. "]},{"code":401,"indent":2,"parameters":["you enter the competition.\""]},{"code":101,"indent":2,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":2,"parameters":["\"Is this description correct?\""]},{"code":102,"indent":2,"parameters":[["Yes","No"],1,0,2,0]},{"code":402,"indent":2,"parameters":[0,"Yes"]},{"code":125,"indent":3,"parameters":[0,0,1000]},{"code":121,"indent":3,"parameters":[7,7,0]},{"code":113,"indent":3,"parameters":[]},{"code":0,"indent":3,"parameters":[]},{"code":402,"indent":2,"parameters":[1,"No"]},{"code":119,"indent":3,"parameters":["Back"]},{"code":0,"indent":3,"parameters":[]},{"code":404,"indent":2,"parameters":[]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[2,"A veteran of the war"]},{"code":101,"indent":2,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":2,"parameters":["\"Your country is strong and powerful,\\. but its foundations "]},{"code":401,"indent":2,"parameters":["were built upon the backs of racially disenfranchised "]},{"code":401,"indent":2,"parameters":["slaves, displaced natives, and other abused groups.\""]},{"code":101,"indent":2,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":2,"parameters":["\"As the practice of slavery became more controversial,\\."]},{"code":401,"indent":2,"parameters":["some regions chose to ban it.\\. Others clung to their "]},{"code":401,"indent":2,"parameters":["warped traditions,\\. leading to a civil war."]},{"code":101,"indent":2,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":2,"parameters":["\"You enlisted in the army of the 'free states'.\""]},{"code":101,"indent":2,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":2,"parameters":["\"Your side won...\\. but e segregation, harassment, and all "]},{"code":401,"indent":2,"parameters":["kinds of injustice still exist. Sometimes you wonder if your "]},{"code":401,"indent":2,"parameters":["service changed anything at all.\""]},{"code":101,"indent":2,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":2,"parameters":["\"Years later,\\. you decided to enter the Steel Ball Run. "]},{"code":401,"indent":2,"parameters":["But for whose sake - for others, or yourself?\""]},{"code":101,"indent":2,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":2,"parameters":["\"Is this description correct?\""]},{"code":102,"indent":2,"parameters":[["Yes","No"],1,0,2,0]},{"code":402,"indent":2,"parameters":[0,"Yes"]},{"code":121,"indent":3,"parameters":[8,8,0]},{"code":113,"indent":3,"parameters":[]},{"code":0,"indent":3,"parameters":[]},{"code":402,"indent":2,"parameters":[1,"No"]},{"code":119,"indent":3,"parameters":["Back"]},{"code":0,"indent":3,"parameters":[]},{"code":404,"indent":2,"parameters":[]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[3,"A free-spirited cowboy"]},{"code":101,"indent":2,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":2,"parameters":["\"You're a criminal with no home but the frontier.\\. The Wild "]},{"code":401,"indent":2,"parameters":["West.\\. How you got there is anyone's guess,\\. but since "]},{"code":401,"indent":2,"parameters":["your first robbery, you've racked up a fearsome reputation.\""]},{"code":101,"indent":2,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":2,"parameters":["\"Bearing many names,\\. you wreak havoc against lawmen and "]},{"code":401,"indent":2,"parameters":["fellow outlaws alike,\\. living only for yourself.\\. "]},{"code":401,"indent":2,"parameters":["Aside from the occassional job team-up,\\. you work alone.\""]},{"code":101,"indent":2,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":2,"parameters":["\"Your sole true ally was your steed.\\. The most trusty "]},{"code":401,"indent":2,"parameters":["companion a lowlife like you could rely on...\\. "]},{"code":401,"indent":2,"parameters":["It was a shame when you lost her.\""]},{"code":101,"indent":2,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":2,"parameters":["\"Down on your luck,\\. old enemies coming down on you from "]},{"code":401,"indent":2,"parameters":["all sides,\\. you thought you were done for. Until you saw a"]},{"code":401,"indent":2,"parameters":["poster advertising a race:\\. the Steel Ball Run.\""]},{"code":101,"indent":2,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":2,"parameters":["\"Is that correct?\""]},{"code":102,"indent":2,"parameters":[["Yes","No"],1,0,2,0]},{"code":402,"indent":2,"parameters":[0,"Yes"]},{"code":121,"indent":3,"parameters":[9,9,0]},{"code":113,"indent":3,"parameters":[]},{"code":0,"indent":3,"parameters":[]},{"code":402,"indent":2,"parameters":[1,"No"]},{"code":119,"indent":3,"parameters":["Back"]},{"code":0,"indent":3,"parameters":[]},{"code":404,"indent":2,"parameters":[]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[4,"You don't need to know"]},{"code":101,"indent":2,"parameters":["",0,0,2,"???"]},{"code":401,"indent":2,"parameters":["\"Heh-heh-heh...\\. Very well then.\\. The absence of an answer "]},{"code":401,"indent":2,"parameters":["is an answer too after all...\""]},{"code":121,"indent":2,"parameters":[5,5,0]},{"code":113,"indent":2,"parameters":[]},{"code":0,"indent":2,"parameters":[]},{"code":404,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":413,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["\"Now, are you a boy or a girl?\\. Forgive me,\\. it's not easy "]},{"code":401,"indent":0,"parameters":["to tell with these old eyes...\""]},{"code":102,"indent":0,"parameters":[["Man","Woman"],1,0,2,0]},{"code":402,"indent":0,"parameters":[0,"Man"]},{"code":121,"indent":1,"parameters":[3,3,0]},{"code":111,"indent":1,"parameters":[0,6,0]},{"code":322,"indent":2,"parameters":[1,"Player",3,"",0,""]},{"code":0,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":111,"indent":1,"parameters":[0,7,0]},{"code":322,"indent":2,"parameters":[1,"Player",5,"",0,""]},{"code":0,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":111,"indent":1,"parameters":[0,8,0]},{"code":322,"indent":2,"parameters":[1,"Player",7,"",0,""]},{"code":0,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":111,"indent":1,"parameters":[0,9,0]},{"code":322,"indent":2,"parameters":[1,"Player",1,"",0,""]},{"code":0,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[1,"Woman"]},{"code":121,"indent":1,"parameters":[3,3,1]},{"code":111,"indent":1,"parameters":[0,6,0]},{"code":322,"indent":2,"parameters":[1,"Player",2,"",0,""]},{"code":0,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":111,"indent":1,"parameters":[0,7,0]},{"code":322,"indent":2,"parameters":[1,"Player",4,"",0,""]},{"code":0,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":111,"indent":1,"parameters":[0,8,0]},{"code":322,"indent":2,"parameters":[1,"Player",6,"",0,""]},{"code":0,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":111,"indent":1,"parameters":[0,9,0]},{"code":322,"indent":2,"parameters":[1,"Player",0,"",0,""]},{"code":0,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":404,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":0,"parameters":["\"I see,\\. well then.\\. Onto the more interesting-\"\\^"]},{"code":241,"indent":0,"parameters":[{"name":"","volume":90,"pitch":100,"pan":0}]},{"code":250,"indent":0,"parameters":[{"name":"record-scratch_1(cut)","volume":50,"pitch":100,"pan":0}]},{"code":101,"indent":0,"parameters":["",0,0,2,"Angry Voice"]},{"code":401,"indent":0,"parameters":["\"Hey! HEY!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":0,"parameters":["\"...Uh oh.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Angry Voice"]},{"code":401,"indent":0,"parameters":["\"How many times must I tell you woman!\\. Quit selling your "]},{"code":401,"indent":0,"parameters":["\"services\" on my private property!\\. Damn it, I'm getting "]},{"code":401,"indent":0,"parameters":["the police!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":0,"parameters":["\"Erm.\\. I-It seems I must go!\\. My apologies... \\."]},{"code":401,"indent":0,"parameters":["No refunds!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Fortune Teller"]},{"code":401,"indent":0,"parameters":["\"...\\.\\.Goodbye!\""]},{"code":221,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["(...\\.\\.She scampered off with your money...)"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["(...)"]},{"code":230,"indent":0,"parameters":[120]},{"code":101,"indent":0,"parameters":["",0,0,2,"???"]},{"code":401,"indent":0,"parameters":["\"Excuse me,\\. Mr. Steel.\""]},{"code":221,"indent":0,"parameters":[]},{"code":201,"indent":0,"parameters":[0,14,7,6,0,0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":3,"walkAnime":false}],"x":8,"y":0},
