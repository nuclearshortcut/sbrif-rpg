code":101,"indent":0,"parameters":["",0,0,2,"Johnny"]},{"code":401,"indent":0,"parameters":["\"By riding them, I felt like i was in tune with their "]},{"code":401,"indent":0,"parameters":["senses and emotions.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Johnny"]},{"code":401,"indent":0,"parameters":["\"...People love beautiful things. And if that beautiful"]},{"code":401,"indent":0,"parameters":["thing is in motion... nothing surpasses it.\""]},{"code":221,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2,"Johnny"]},{"code":401,"indent":0,"parameters":["\"'Johnny Joestar has talent!', said an old groom. And I got"]},{"code":401,"indent":0,"parameters":["encouraged.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Johnny"]},{"code":401,"indent":0,"parameters":["\"But my father never cared about me... My older brother "]},{"code":401,"indent":0,"parameters":["Nicholas was already in the spotlight.\""]},{"code":201,"indent":0,"parameters":[0,66,9,13,0,0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":2,"indent":null},{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":4,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true}],"x":12,"y":7}
