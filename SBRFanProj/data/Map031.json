{"id":1,"name":"Sheriff","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"Civilian3","direction":2,"pattern":1,"characterIndex":3},"list":[{"code":205,"indent":0,"parameters":[2,{"list":[{"code":17,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":17,"indent":null}]},{"code":101,"indent":0,"parameters":["",0,0,2,"Sheriff"]},{"code":401,"indent":0,"parameters":["\"This is ridiculous...\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Sheriff"]},{"code":401,"indent":0,"parameters":["\"It's like this race has attracted all the miscreants in the"]},{"code":401,"indent":0,"parameters":["nation to this town!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Sheriff"]},{"code":401,"indent":0,"parameters":["\"I don't know how the government expects us to handle it "]},{"code":401,"indent":0,"parameters":["all! We've hardly left our frontier era! We only have a "]},{"code":401,"indent":0,"parameters":["few thousand residents!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Sheriff"]},{"code":401,"indent":0,"parameters":["\"That Steel should've taken this fiasco to San Francisco...\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Mt. Tim"]},{"code":401,"indent":0,"parameters":["\"Sorry I couldn't be of more help sheriff.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Sheriff"]},{"code":401,"indent":0,"parameters":["\"No, no, don't say that. You've done a lot for us"]},{"code":401,"indent":0,"parameters":["lawmen. And not just lately either!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Mt. Tim"]},{"code":401,"indent":0,"parameters":["\"I've asked around for some volunteers to help out."]},{"code":401,"indent":0,"parameters":["Everyone seems focused on their own problems though. I don't"]},{"code":401,"indent":0,"parameters":["know how many will show up.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Sheriff"]},{"code":401,"indent":0,"parameters":["\"...Well, speak of the devil. Looks to me one's "]},{"code":401,"indent":0,"parameters":["showed up right now.\""]},{"code":205,"indent":0,"parameters":[2,{"list":[{"code":16,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":16,"indent":null}]},{"code":101,"indent":0,"parameters":["",0,0,2,"Mt. Tim"]},{"code":401,"indent":0,"parameters":["\"Well, I suppose there are some good hearts around here "]},{"code":401,"indent":0,"parameters":["after all!\""]},{"code":108,"indent":0,"parameters":["introductions"]},{"code":101,"indent":0,"parameters":["",0,0,2,"Sheriff"]},{"code":401,"indent":0,"parameters":["\"Listen... Mt. Tim thinks you're alright, but to me you're "]},{"code":401,"indent":0,"parameters":["just one of the million racers who've shown up out of the"]},{"code":401,"indent":0,"parameters":["blue.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Sheriff"]},{"code":401,"indent":0,"parameters":["\"I'll give you the 'privilege' of helping us out, but don't "]},{"code":401,"indent":0,"parameters":["get yourself into anything you can't handle!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Sheriff"]},{"code":401,"indent":0,"parameters":["\"There's a list of problems on that there board. Go on and "]},{"code":401,"indent":0,"parameters":["take a look.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Sheriff"]},{"code":401,"indent":0,"parameters":["\"But remember! Don't bite off more than you can chew.\""]},{"code":123,"indent":0,"parameters":["A",0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":true,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"Civilian3","direction":2,"pattern":1,"characterIndex":3},"list":[{"code":101,"indent":0,"parameters":["",0,0,2,"Sheriff"]},{"code":401,"indent":0,"parameters":["\"Go look over the board. If you ain't gonna help, make "]},{"code":401,"indent":0,"parameters":["yourself scarce.\""]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":5,"variableValid":true,"variableValue":4},"directionFix":false,"image":{"tileId":0,"characterName":"Civilian3","direction":2,"pattern":1,"characterIndex":3},"list":[{"code":221,"indent":0,"parameters":[]},{"code":201,"indent":0,"parameters":[0,31,6,5,0,0]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2,"Sheriff"]},{"code":401,"indent":0,"parameters":["\"Well outsider, I suppose you're more reliable than I "]},{"code":401,"indent":0,"parameters":["thought!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Sheriff"]},{"code":401,"indent":0,"parameters":["\"You surpassed my expectations. Thank you! Here's a token "]},{"code":401,"indent":0,"parameters":["of my appreciation!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Sheriff"]},{"code":401,"indent":0,"parameters":["\"If this racing business doesn't work out for you, come "]},{"code":401,"indent":0,"parameters":["back here and I'll get you some work under me! We could use"]},{"code":401,"indent":0,"parameters":["someone like you!\""]},{"code":123,"indent":0,"parameters":["B",0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"B","selfSwitchValid":true,"switch1Id":99,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":5,"variableValid":false,"variableValue":4},"directionFix":false,"image":{"tileId":0,"characterName":"Civilian3","direction":2,"pattern":1,"characterIndex":3},"list":[{"code":101,"indent":0,"parameters":["",0,0,2,"Sheriff"]},{"code":401,"indent":0,"parameters":["\"Good luck in the Run!\""]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":6,"y":3},
{"id":2,"name":"MountainTim","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"NamedRacer0","direction":2,"pattern":1,"characterIndex":5},"list":[{"code":101,"indent":0,"parameters":["",0,0,2,"Mt. Tim"]},{"code":401,"indent":0,"parameters":["\"Don't feel too bad if you don't feel up for this. Good "]},{"code":401,"indent":0,"parameters":["luck if you do though!\""]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":99,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":5,"variableValid":true,"variableValue":4},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":8,"y":3},
{"id":3,"name":"Board","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":111,"indent":0,"parameters":[1,5,0,4,0]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["(There's nothing left to do.)"]},{"code":0,"indent":1,"parameters":[]},{"code":411,"indent":0,"parameters":[]},{"code":102,"indent":1,"parameters":[["1. Opium Den","2. Violent Gang","3. Illicit Business"],1,0,2,0]},{"code":402,"indent":1,"parameters":[0,"1. Opium Den"]},{"code":111,"indent":2,"parameters":[1,3,0,2,0]},{"code":101,"indent":3,"parameters":["",0,0,2,""]},{"code":401,"indent":3,"parameters":["(You've completed this task. The notice was removed.)"]},{"code":0,"indent":3,"parameters":[]},{"code":411,"indent":2,"parameters":[]},{"code":101,"indent":3,"parameters":["",0,0,2,""]},{"code":401,"indent":3,"parameters":["'A lot of boats have been coming into the docks the past "]},{"code":401,"indent":3,"parameters":["few weeks, bringing over foreign racers and spectators.'"]},{"code":101,"indent":3,"parameters":["",0,0,2,""]},{"code":401,"indent":3,"parameters":["'Smugglers have been using the commotion to sneak in opium.'"]},{"code":101,"indent":3,"parameters":["",0,0,2,""]},{"code":401,"indent":3,"parameters":["'They likely have a hidden den somewhere in town where "]},{"code":401,"indent":3,"parameters":["they're hiding those drugs.'"]},{"code":101,"indent":3,"parameters":["",0,0,2,""]},{"code":401,"indent":3,"parameters":["'They've only gotten sneakier the last time they were "]},{"code":401,"indent":3,"parameters":["exposed. They've gotta be right *under* our noses.'"]},{"code":122,"indent":3,"parameters":[3,3,0,0,1]},{"code":0,"indent":3,"parameters":[]},{"code":412,"indent":2,"parameters":[]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[1,"2. Violent Gang"]},{"code":111,"indent":2,"parameters":[1,2,0,3,0]},{"code":101,"indent":3,"parameters":["",0,0,2,""]},{"code":401,"indent":3,"parameters":["(You've completed this task. The notice was removed.)"]},{"code":0,"indent":3,"parameters":[]},{"code":411,"indent":2,"parameters":[]},{"code":101,"indent":3,"parameters":["",0,0,2,""]},{"code":401,"indent":3,"parameters":["'Everywhere has its fair share of criminality. Small town"]},{"code":401,"indent":3,"parameters":["like this though? The local troublemakers are well known"]},{"code":401,"indent":3,"parameters":["and don't act outside of your expectations.'"]},{"code":101,"indent":3,"parameters":["",0,0,2,""]},{"code":401,"indent":3,"parameters":["'But that's changed as of late. The town has begun to grow"]},{"code":401,"indent":3,"parameters":["a lot the past few years with that new hotel, the railroad,"]},{"code":401,"indent":3,"parameters":["and all this chaos surrounding the race...'"]},{"code":101,"indent":3,"parameters":["",0,0,2,""]},{"code":401,"indent":3,"parameters":["'The crooks have gotten more organized and uncontrollable. "]},{"code":401,"indent":3,"parameters":["For the last few days, a gang's been going as far as"]},{"code":401,"indent":3,"parameters":["attacking newcomers and raiding private property.'"]},{"code":101,"indent":3,"parameters":["",0,0,2,""]},{"code":401,"indent":3,"parameters":["'If we can't settle this, our worthiness of the badge will"]},{"code":401,"indent":3,"parameters":["come into question. If we cut off the head of the snake,"]},{"code":401,"indent":3,"parameters":["the robbers should at least reel in their crimes for a "]},{"code":401,"indent":3,"parameters":["while."]},{"code":101,"indent":3,"parameters":["",0,0,2,""]},{"code":401,"indent":3,"parameters":["'I'm betting they're based in the cesspit of this town, "]},{"code":401,"indent":3,"parameters":["Stingaree...\""]},{"code":122,"indent":3,"parameters":[2,2,0,0,1]},{"code":0,"indent":3,"parameters":[]},{"code":412,"indent":2,"parameters":[]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[2,"3. Illicit Business"]},{"code":111,"indent":2,"parameters":[1,4,0,3,0]},{"code":101,"indent":3,"parameters":["",0,0,2,""]},{"code":401,"indent":3,"parameters":["(You've completed this task. The notice was removed.)"]},{"code":0,"indent":3,"parameters":[]},{"code":411,"indent":2,"parameters":[]},{"code":101,"indent":3,"parameters":["",0,0,2,""]},{"code":401,"indent":3,"parameters":["'We were willing to overlook the... professions some women "]},{"code":401,"indent":3,"parameters":["took on during the older days. But times have changed.'"]},{"code":101,"indent":3,"parameters":["",0,0,2,""]},{"code":401,"indent":3,"parameters":["'With eyes all over this town - two belonging to the "]},{"code":401,"indent":3,"parameters":["President himself - we need to shape up.'"]},{"code":101,"indent":3,"parameters":["",0,0,2,""]},{"code":401,"indent":3,"parameters":["'But one particular saloon owner has been stubborn. He's "]},{"code":401,"indent":3,"parameters":["done a good job of protecting his 'second business'. Not "]},{"code":401,"indent":3,"parameters":["just anyone can be a patron anymore.'"]},{"code":101,"indent":3,"parameters":["",0,0,2,""]},{"code":401,"indent":3,"parameters":["'It's difficult to find evidence against him under those "]},{"code":401,"indent":3,"parameters":["circumstances. Without proof, there's nothing we can do to "]},{"code":401,"indent":3,"parameters":["expose him.'"]},{"code":122,"indent":3,"parameters":[4,4,0,0,1]},{"code":0,"indent":3,"parameters":[]},{"code":412,"indent":2,"parameters":[]},{"code":0,"indent":2,"parameters":[]},{"code":404,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":412,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"m