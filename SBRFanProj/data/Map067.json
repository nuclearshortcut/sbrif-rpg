{"id":1,"name":"Johnny","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"$HorseJohnny","direction":4,"pattern":1,"characterIndex":0},"list":[{"code":222,"indent":0,"parameters":[]},{"code":205,"indent":0,"parameters":[-1,{"list":[{"code":29,"parameters":[6],"indent":null},{"code":2,"indent":null},{"code":0}],"repeat":true,"skippable":false,"wait":false}]},{"code":505,"indent":0,"parameters":[{"code":29,"parameters":[6],"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":2,"indent":null}]},{"code":205,"indent":0,"parameters":[1,{"list":[{"code":29,"parameters":[6],"indent":null},{"code":2,"indent":null},{"code":0}],"repeat":true,"skippable":false,"wait":false}]},{"code":505,"indent":0,"parameters":[{"code":29,"parameters":[6],"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":2,"indent":null}]},{"code":101,"indent":0,"parameters":["",0,0,2,"Johnny"]},{"code":401,"indent":0,"parameters":["\"After my brother's death, I began racing seriously, winning"]},{"code":401,"indent":0,"parameters":["over and over again.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Johnny"]},{"code":401,"indent":0,"parameters":["\"Politicians, royalty, socialites, women... They treated me "]},{"code":401,"indent":0,"parameters":["like a prodigy!\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Johnny"]},{"code":401,"indent":0,"parameters":["\"With each victory, they flattered me with gifts, calling me "]},{"code":401,"indent":0,"parameters":["'JoJo' or 'Joe Kid' with praise.\""]},{"code":101,"indent":0,"parameters":["",0,0,2,"Johnny"]},{"code":401,"indent":0,"parameters":["\"Winning on horseback was a symbol of triumph. It marked me "]},{"code":401,"indent":0,"parameters":["with authority and power.\""]},{"code":221,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2,"Johnny"]},{"code":401,"indent":0,"parameters":["\"But it didn't last long.\""]},{"code":201,"indent":0,"parameters":[0,54,19,7,0,0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true}],"x":6,"y":15},
